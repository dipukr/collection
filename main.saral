record Person(String name, int age, int sal)

class FileReader
{
    val File file

    pub FileReader(File file) {
        this.file = file
    }

    pub ByteStream readAll() {
        byte[] data = new byte[10000]
        val reader = new DataStreamReader(file)
        while (true)
            reader.read(data)
        return ByteStream.of(data)
    }
}

class Person
{
   val name as String;
   val age as int;
   val sal as int;

    pub Person(val name as String, val age as int, val sal as int) {
        this.name = name;
        this.age = age;
        this.sal = sal;
    }

    pub void draw(val canvas as Canvas) {
        val person = Person.builder()
            .name("name")
            .age(20)
            .sal(40000)
            .build();
        canvas.draw("name={name}");
        canvas.draw("age={age}");
        canvas.draw("sal={sal}");
    }
}

