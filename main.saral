class Person
{
	String name;
	int age;
	int sal;

	Self(String name, int age, int sal) {
		this.name = name;
		this.age = age;
		this.sal = sal;
	}
}

void main(String[] args)
{
	let user = new Person("DeePoo", 30, 50000);
	mut user = new Person("DeePoo", 30, 50000);
	int[] data = [10, 20, 30, 40, 50, 60, 70];
	bool[] marked = new bool[data.length];
	mut int iter = 0;
	while (iter < data.length) {
		logger(data[iter]);
		iter += 1;
	}
}