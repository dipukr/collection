interface Clone<T> => T clone();

record Person(String name, int age, int sal)

int add<Number>(Number a, Number b) {return a + b;}

class Person
{
    String name;
    int age;
    int sal;

    pub Self(String name, int age, int sal) {
        self.name = name;
        self.age = age;
        self.sal = sal;
    }

    pub void draw(Canvas canvas) {
        logger("Name:", self.name);
        logger(self.age);
        logger(self.sal);
    }
}



