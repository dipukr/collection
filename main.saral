class Person
{
	mut String name;
	mut int age;
	mut int sal;
	
	pub Self(String name, int age, int sal) {
		self.name = name;
		self.age = age;
		self.sal = sal;
	}

	pub String Format(Formatter formatter) {
		return formatter.Format(this);
	}
}

interface Converter<Src, Dest> {
	Src Column(F data);
	Dest Field(T data);
}



