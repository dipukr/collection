public interface Visitor<R> {
		R visit(ClassDecl statement);
		R visit(Function statement);
		R visit(Block statement);
		R visit(VarDecl statement);
		R visit(If statement);
		R visit(While statement);
		R visit(Foreach statement);
		R visit(Break statement);
		R visit(Return statement);
		R visit(Assert statement);
		R visit(Console statement);
		R visit(Expresion statement);
	}