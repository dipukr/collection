public void writeToExcels(Workbook workbook, Date date, Map<String, String> meters, List<DSMConventionalDayWiseChargeCalculationDTO> blockWiseDSMCharges,
		CellStyle headerCellStyle, CellStyle cellStyleQuant, CellStyle cellStyleRs, CellStyle cellStyle, String customerName,
		String filePath, String entityType, String entityCategory, Boolean isMeterDetails, Boolean isNr, String sheetName) throws BusinessException {
	DateFormat df = new SimpleDateFormat("dd-MM-yyyy");
	CaptiveCharge captiveCharge = getCaptiveCharge(date);
	Map<Integer, Double> normalRateMap = this.getNormalRate(date);
	Sheet sheet = workbook.createSheet(sheetName);
	sheet.setDefaultColumnWidth(17);
	List<DSMConventionalDayWiseChargeCalculationDTO> dateWiseFilteredList = blockWiseDSMCharges.stream()
			.filter(elem -> elem.getForDate().equals(date)).collect(Collectors.toList());
	ExcelHelper.mergeRegion(sheet, 0, 4, 2, 14);

	ExcelHelper.mergeRegion(sheet, 0, 1, 0, 0);
	ExcelHelper.mergeRegion(sheet, 0, 1, 1, 1);
	ExcelHelper.mergeRegion(sheet, 2, 4, 0, 0);
	ExcelHelper.mergeRegion(sheet, 2, 4, 1, 1);

	sheet.setColumnWidth(0, 25 * 256);
	sheet.setColumnWidth(1, 25 * 256);

	Row firstRow = sheet.createRow(0);
	ExcelHelper.createCell(firstRow, 0, headerCellStyle, "Name of Customer");
	ExcelHelper.createCell(firstRow, 1, cellStyle, customerName);
	firstRow = sheet.createRow(2);
	ExcelHelper.createCell(firstRow, 0, headerCellStyle, "Date");
	ExcelHelper.createCell(firstRow, 1, cellStyle, sdf.format(date));
	
	Boolean isDiscom = DSMEntityCategory.BUYER_GEN.equals(entityCategory) && entityType.equals("Distribution-Licensee");

	exportHeaderImageToExcel(workbook, sheet, 0, 4, 3, 9, filePath);
	Map<String, Integer> meterWiseColNo = generateTBWiseHeader(sheet, headerCellStyle, 5, meters, isMeterDetails, isNr, isDiscom);
	generateTBWiseDataBody(workbook, sheet, cellStyle, cellStyleQuant, cellStyleRs, dateWiseFilteredList, 12,
			meters, captiveCharge, normalRateMap, isMeterDetails, isNr, isDiscom, meterWiseColNo);
	ExcelHelper.setBorderOnMergeCell(sheet);
}

public void generateForDiscom(Workbook workbook, CellStyle headerCellStyle, String customerName,
		DSMBillingRequestDTO billingRequestDTO,
		List<DSMConventionalDayWiseChargeCalculationDTO> blockWiseDSMCharges, CellStyle cellStyle,
		CellStyle cellStyleQuant, CellStyle cellStyleRs, String sheetName, Boolean isMeterDetails, Boolean isNr)
		throws BusinessException {
	Date fromDate = billingRequestDTO.getFromDate();
	Date toDate = billingRequestDTO.getToDate();
	String filePath = billingRequestDTO.getFilePath();
	String entityType = billingRequestDTO.getEntityType();
	String entityCategory = billingRequestDTO.getEntityCategory();
	boolean isDiscom = DSMEntityCategory.BUYER_GEN.equals(entityCategory) && entityType.equals("Distribution-Licensee");

	Map<String, String> meters = getMeters(billingRequestDTO.getEntityUtgId());
	List<Thread> threads = new ArrayList<>();
	for (Date date = fromDate; date.before(toDate) || date.equals(toDate); date = DateUtils.addDays(date, 1)) {
		final Date fdate = date;
		Thread thread1 = new Thread(() -> {
			try {
				writeToExcels(workbook, fdate, meters, blockWiseDSMCharges, 
						headerCellStyle, cellStyleQuant, cellStyleRs, cellStyle, customerName, filePath, entityType, 
						entityCategory, isMeterDetails, isNr, "TBwise with meter_"+sdf.format(fdate));
			} catch (BusinessException e) {
				e.printStackTrace();
			}
		});
		Thread thread2 = new Thread(() -> {
			try {
				writeToExcels(workbook, fdate, meters, blockWiseDSMCharges, 
						headerCellStyle, cellStyleQuant, cellStyleRs, cellStyle, customerName, filePath, entityType, 
						entityCategory, isMeterDetails, isNr, "TBwise with meter_"+sdf.format(fdate));
			} catch (BusinessException e) {
				e.printStackTrace();
			}
		});
		threads.add(thread1);
		threads.add(thread2);
		thread1.start();
		thread2.start();
	}
	for (Thread thread: threads) {
		try {
			thread.join();
		} catch (InterruptedException e) {
			e.printStackTrace();
		}
	}
}
