public abstract Expr {
	public Expr() {}
	public abstract void accept(Visitor visitor);
}
public Add extends Expr {
	public Expr a;
	public Expr b;
	public Add(Expr a, Expr b) {
		this.a = a;
		this.b = b;
	}
	public void accept(Visitor visitor) {
		visitor.visit(this);
	}
}
public Sub extends Expr {
	public Expr a;
	public Expr b;
	public Sub(Expr a, Expr b) {
		this.a = a;
		this.b = b;
	}
	public void accept(Visitor visitor) {
		visitor.visit(this);
	}
}
public Constant extends Expr {
	public double val;
	public Constant(double val) {
		this.val = val;
	}
	public void accept(Visitor visitor) {
		visitor.visit(this);
	}
}
public interface Visitor {
	void visit(Add expr);
	void visit(Sub expr);
	void visit(Constant expr);
}
