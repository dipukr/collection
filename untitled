import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.concurrent.Executors;
import java.util.concurrent.ScheduledExecutorService;
import java.util.concurrent.TimeUnit;

// Enum for job and step status
enum Status {
    PENDING, RUNNING, COMPLETED, FAILED
}

// Interfaces for Reader, Processor, and Writer
interface ItemReader<T> {
    T read() throws Exception;
}

interface ItemProcessor<I, O> {
    O process(I item) throws Exception;
}

interface ItemWriter<T> {
    void write(List<T> items) throws Exception;
}

// Job interface
interface Job {
    String getName();
    Step getStep();
}

// Step interface for Reader-Processor-Writer
interface Step {
    void execute(JobExecutionContext context) throws Exception;
}

// Job execution context to hold runtime data
class JobExecutionContext {
    private Map<String, Object> jobParameters = new HashMap<>();
    private Map<String, Object> executionContext = new HashMap<>();

    public void putParameter(String key, Object value) {
        jobParameters.put(key, value);
    }

    public Object getParameter(String key) {
        return jobParameters.get(key);
    }

    public void put(String key, Object value) {
        executionContext.put(key, value);
    }

    public Object get(String key) {
        return executionContext.get(key);
    }
}

// Job execution to track status and context
class JobExecution {
    private final Job job;
    private Status status;
    private LocalDateTime startTime;
    private LocalDateTime endTime;
    private JobExecutionContext context;
    private String errorMessage;

    public JobExecution(Job job) {
        this.job = job;
        this.status = Status.PENDING;
        this.context = new JobExecutionContext();
    }

    public Job getJob() {
        return job;
    }

    public Status getStatus() {
        return status;
    }

    public void setStatus(Status status) {
        this.status = status;
    }

    public LocalDateTime getStartTime() {
        return startTime;
    }

    public void setStartTime(LocalDateTime startTime) {
        this.startTime = startTime;
    }

    public LocalDateTime getEndTime() {
        return endTime;
    }

    public void setEndTime(LocalDateTime endTime) {
        this.endTime = endTime;
    }

    public JobExecutionContext getContext() {
        return context;
    }

    public String getErrorMessage() {
        return errorMessage;
    }

    public void setErrorMessage(String errorMessage) {
        this.errorMessage = errorMessage;
    }
}

// Simple job repository to store job executions
class JobRepository {
    private Map<String, List<JobExecution>> executions = new HashMap<>();

    public void save(JobExecution execution) {
        executions.computeIfAbsent(execution.getJob().getName(), k -> new ArrayList<>()).add(execution);
    }

    public List<JobExecution> getExecutions(String jobName) {
        return executions.getOrDefault(jobName, new ArrayList<>());
    }
}

// Chunk-oriented step implementation
class ChunkStep<T, U> implements Step {
    private ItemReader<T> reader;
    private ItemProcessor<T, U> processor;
    private ItemWriter<U> writer;
    private int chunkSize;

    public ChunkStep(ItemReader<T> reader, ItemProcessor<T, U> processor, ItemWriter<U> writer, int chunkSize) {
        this.reader = reader;
        this.processor = processor;
        this.writer = writer;
        this.chunkSize = chunkSize;
    }

    @Override
    public void execute(JobExecutionContext context) throws Exception {
        List<U> chunk = new ArrayList<>();
        T item;

        while ((item = reader.read()) != null) {
            U processedItem = processor.process(item);
            if (processedItem != null) {
                chunk.add(processedItem);
            }

            if (chunk.size() >= chunkSize) {
                writer.write(chunk);
                chunk.clear();
            }
        }

        if (!chunk.isEmpty()) {
            writer.write(chunk);
        }
    }
}

// Job launcher to execute jobs
class JobLauncher {
    private JobRepository repository;
    private int maxRetries;
    private long retryDelayMillis;

    public JobLauncher(JobRepository repository, int maxRetries, long retryDelayMillis) {
        this.repository = repository;
        this.maxRetries = maxRetries;
        this.retryDelayMillis = retryDelayMillis;
    }

    public JobExecution run(Job job, Map<String, Object> parameters) {
        JobExecution execution = new JobExecution(job);
        execution.getContext().putParameter("parameters", parameters);
        repository.save(execution);

        execution.setStartTime(LocalDateTime.now());
        execution.setStatus(Status.RUNNING);

        int attempt = 0;
        boolean success = false;

        while (attempt <= maxRetries && !success) {
            try {
                job.getStep().execute(execution.getContext());
                success = true;
            } catch (Exception e) {
                attempt++;
                if (attempt > maxRetries) {
                    execution.setStatus(Status.FAILED);
                    execution.setErrorMessage("Job failed after " + maxRetries + " retries: " + e.getMessage());
                    execution.setEndTime(LocalDateTime.now());
                    repository.save(execution);
                    return execution;
                }
                try {
                    Thread.sleep(retryDelayMillis);
                } catch (InterruptedException ie) {
                    Thread.currentThread().interrupt();
                }
            }
        }

        execution.setStatus(Status.COMPLETED);
        execution.setEndTime(LocalDateTime.now());
        repository.save(execution);
        return execution;
    }
}

// Simple cron-like scheduler
class SimpleScheduler {
    private ScheduledExecutorService executor = Executors.newScheduledThreadPool(1);
    private JobLauncher launcher;
    private JobRepository repository;

    public SimpleScheduler(JobLauncher launcher, JobRepository repository) {
        this.launcher = launcher;
        this.repository = repository;
    }

    public void schedule(Job job, String cronExpression, Map<String, Object> parameters) {
        int intervalSeconds = parseCronInterval(cronExpression);
        executor.scheduleAtFixedRate(() -> {
            System.out.println("Scheduling job: " + job.getName() + " at " + LocalDateTime.now());
            launcher.run(job, parameters);
        }, 0, intervalSeconds, TimeUnit.SECONDS);
    }

    private int parseCronInterval(String cronExpression) {
        String[] parts = cronExpression.split(" ");
        if (parts[0].startsWith("*/")) {
            return Integer.parseInt(parts[0].substring(2));
        }
        return 60; // Default to 60 seconds
    }

    public void shutdown() {
        executor.shutdown();
    }
}

// Example job implementation
class SampleJob implements Job {
    private String name;
    private Step step;

    public SampleJob(String name, Step step) {
        this.name = name;
        this.step = step;
    }

    @Override
    public String getName() {
        return name;
    }

    @Override
    public Step getStep() {
        return step;
    }
}

// Example Reader, Processor, and Writer implementations
class SampleItemReader implements ItemReader<String> {
    private List<String> items = new ArrayList<>();
    private int index = 0;
    private boolean shouldFail;

    public SampleItemReader(boolean shouldFail) {
        this.shouldFail = shouldFail;
        items.add("Item1");
        items.add("Item2");
        items.add("Item3");
    }

    @Override
    public String read() throws Exception {
        if (shouldFail && index == 1) {
            throw new RuntimeException("Reader failed intentionally on Item2");
        }
        if (index < items.size()) {
            return items.get(index++);
        }
        return null; // Indicates end of data
    }
}

class SampleItemProcessor implements ItemProcessor<String, String> {
    @Override
    public String process(String item) throws Exception {
        System.out.println("Processing item: " + item);
        return "Processed_" + item;
    }
}

class SampleItemWriter implements ItemWriter<String> {
    @Override
    public void write(List<String> items) throws Exception {
        System.out.println("Writing items: " + items);
    }
}

// Main class to demonstrate the batch system
public class BatchProcessingSystem {
    public static void main(String[] args) {
        // Initialize components
        JobRepository repository = new JobRepository();
        JobLauncher launcher = new JobLauncher(repository, 2, 1000); // 2 retries, 1-second delay
        SimpleScheduler scheduler = new SimpleScheduler(launcher, repository);

        // Create a sample job with a chunk-oriented step
        ItemReader<String> reader = new SampleItemReader(true); // Set to fail on second item
        ItemProcessor<String, String> processor = new SampleItemProcessor();
        ItemWriter<String> writer = new SampleItemWriter();
        Step step = new ChunkStep<>(reader, processor, writer, 2); // Process in chunks of 2
        Job job = new SampleJob("SampleJob", step);

        // Schedule the job to run every 5 seconds
        Map<String, Object> parameters = new HashMap<>();
        parameters.put("param1", "value1");
        scheduler.schedule(job, "*/5 * * * * *", parameters);

        // Run for 15 seconds to observe a few executions
        try {
            Thread.sleep(15000);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }

        // Shutdown scheduler
        scheduler.shutdown();

        // Print job execution history
        System.out.println("\nJob Execution History:");
        for (JobExecution execution : repository.getExecutions("SampleJob")) {
            System.out.printf("Job: %s, Status: %s, Start: %s, End: %s, Error: %s%n",
                    execution.getJob().getName(),
                    execution.getStatus(),
                    execution.getStartTime(),
                    execution.getEndTime(),
                    execution.getErrorMessage());
        }
    }
}
