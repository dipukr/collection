public Statement parseForeachStatement(List<Statement> statements) {
	int pos = tokens.currPos();
	tokens.match(Token.FOREACH);
	tokens.match(Token.LPAREN);
	Statement.VarDecl decl = parseVarDecl2();
	Expression init = null;
	Expression target = null;
	Statement statement = null;
	
	tokens.match(Token.COLON);
	Expression expression = parseExpression();
	if (tokens.currToken() == Token.DOTS) {
		init = expression;
		tokens.match(Token.DOTS);
		target = parseExpression();
		tokens.match(Token.RPAREN);
		statement = parseStatement();
	} else {
		target = expression;
		tokens.match(Token.RPAREN);
		statement = parseStatement();
	}
	if (init == null)
		return new Statement.Foreach(decl, target, statement, pos);
	decl.initVal = init;
	statements.add(decl);
	Expression left = new Expression.Identifier(decl.sym, pos);
	Expression condition = getWhileCondition(left, target);
	Statement stat = null;
	if (statement instanceof Statement.Block block) {
		block.statements.add(stat);
	} else {
		List<Statement> stats = new ArrayList<>();
		stats.add(statement);
		stats.add(getWhileUpdateStatement(left, pos));
		statement = new Statement.Block(stats, pos);
	}
	return new Statement.While(condition, statement, pos);
}

public Statement getWhileUpdateStatement(Expression left, int pos) {
