#!/usr/bin/python3.12

from PyQt6.QtWidgets import *
from PyQt6.QtCore import *
from PyQt6.QtGui import *
import requests
import sys

class QWidget_1(QWidget):
	def __init__(self):
		super().__init__()
		self.layout = QHBoxLayout()
		self.layout.addWidget(QPushButton("A"), 0)
		self.layout.addWidget(QPushButton("B"), 1)
		self.layout.addWidget(QPushButton("C"), 2)
		self.setLayout(self.layout)
		self.rect = QRect(10, 10, 100, 200)


class QWidget_2(QWidget):
	def __init__(self):
		super().__init__()
		self.spinBox = QSpinBox()
		self.spinBox.setValue(30)
		self.spinBox.setRange(0, 130)
		self.slider = QSlider(Qt.Orientation.Horizontal)
		self.slider.setRange(0, 130)
		self.slider.setValue(100)
		self.layout = QHBoxLayout()
		self.layout.addWidget(self.spinBox)
		self.layout.addWidget(self.slider)
