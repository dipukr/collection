		self.slider.valueChanged.connect(self.spinBox.setValue)
		self.spinBox.valueChanged.connect(self.slider.setValue)
		

class QWidget_3(QWidget):
	def __init__(self):
		super().__init__()
		self.slider = QSlider(Qt.Orientation.Horizontal)
		self.slider.setRange(0, 130)
		self.slider.setValue(100)
		self.progressBar = QProgressBar()
		self.progressBar.setRange(0, 130)
		self.progressBar.setValue(100)
		self.layout = QVBoxLayout()
		self.layout.addWidget(self.slider)
		self.layout.addWidget(self.progressBar)
		self.setLayout(self.layout)
		self.slider.valueChanged.connect(self.progressBar.setValue)
		self.progressBar.valueChanged.connect(self.slider.setValue)

class QWidget_4(QWidget):
	def __init__(self):
		super().__init__()
		self.url = QLineEdit()
		self.button = QPushButton("Send")
		self.layout0 = QHBoxLayout()
		self.layout0.addWidget(self.url)
		self.layout0.addWidget(self.button)
		self.request = QTextEdit()
		self.response = QTextEdit()
		self.layout1 = QHBoxLayout()
		self.layout1.addWidget(self.request)
		self.layout1.addWidget(self.response)
		self.mainLayout = QVBoxLayout()
		self.mainLayout.addLayout(self.layout0)
		self.mainLayout.addLayout(self.layout1)
		self.setLayout(self.mainLayout)
		self.button.clicked.connect(self.handleSend)

	def handleSend(self):
		text = requests.get(self.url.text()).text
		self.response.setText(text)

