class Person {
	val name;
	val age;
	val sal;
	constructor(name, age, sal) {
		this.name = name;
		this.age = age;
		this.sal = sal;
	}
	draw(console) {
		console.write(name);
		console.write(age);
		console.write(sal);
	}
}

function main(args) {
	var person = new Person("DeePoo", 30, 50000);
	person.draw();
}

